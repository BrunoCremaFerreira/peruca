# CORS
CORS_ORIGIN=*

# LLM Provider
LLM_PROVIDER_URL=http://<ollama-host>:11434
LLM_PROVIDER_TYPE=OLLAMA
LLM_PROVIDER_API_KEY=

# Reasoning/thinking mode. Leave empty to omit the `think` param (safe default
# for models that reject it). Set to false for thinking models like gemma4 to
# skip ~350-500 wasted reasoning tokens per call (cuts /chat latency ~8x).
# Per-graph overrides exist, e.g. LLM_MAIN_GRAPH_CHAT_REASONING=false
LLM_REASONING=false

# LLM Models
LLM_MAIN_GRAPH_CHAT_MODEL=qwen3:14b
LLM_ONLY_TALK_GRAPH_CHAT_MODEL=qwen3:14b
LLM_SHOPPING_LIST_GRAPH_CHAT_MODEL=qwen3:14b
LLM_SMART_HOME_LIGHTS_GRAPH_CHAT_MODEL=qwen3:14b
LLM_SMART_HOME_CLIMATE_GRAPH_CHAT_MODEL=qwen3:14b
LLM_SMART_HOME_SENSORS_GRAPH_CHAT_MODEL=qwen3:14b
LLM_SMART_HOME_CAMERAS_GRAPH_CHAT_MODEL=qwen3:14b

# Home Assistant
HOME_ASSISTANT_URL=http://<ha-host>:8123
HOME_ASSISTANT_TOKEN=<long-lived-token>

# Databases
PERUCA_DB_CONNECTION_STRING=sqlite:///data/peruca.db
CACHE_DB_CONNECTION_STRING=
