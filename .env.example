# CORS
CORS_ORIGIN=*

# API key. Empty = the API runs WITHOUT authentication (a warning is logged at
# startup). Set it to require the X-API-Key header on every route except
# /health. Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PERUCA_API_KEY=

# Log level: DEBUG, INFO, WARNING, ERROR or CRITICAL (defaults to INFO)
LOG_LEVEL=INFO

# LLM Provider
LLM_PROVIDER_URL=http://<ollama-host>:11434
LLM_PROVIDER_TYPE=OLLAMA
LLM_PROVIDER_API_KEY=

# Reasoning/thinking mode. Defaults to false (thinking off) so gemma4 skips
# ~350-500 wasted reasoning tokens per call (cuts /chat latency ~8x). Set true
# to enable thinking, or empty (LLM_REASONING=) to omit the `think` param for
# models that reject it. Per-graph overrides exist, e.g.
# LLM_MAIN_GRAPH_CHAT_REASONING=true
LLM_REASONING=false

# LLM Models (default: gemma4:12b). Each graph can use a different model.
LLM_MAIN_GRAPH_CHAT_MODEL=gemma4:12b
LLM_ONLY_TALK_GRAPH_CHAT_MODEL=gemma4:12b
LLM_ONLY_TALK_HISTORY_MAX_MESSAGES=30           # cap de mensagens do histórico injetadas no prompt de conversa (evita estourar num_ctx e truncar a resposta); <=0 = histórico completo
LLM_SHOPPING_LIST_GRAPH_CHAT_MODEL=gemma4:12b
LLM_SMART_HOME_LIGHTS_GRAPH_CHAT_MODEL=gemma4:12b
LLM_SMART_HOME_CLIMATE_GRAPH_CHAT_MODEL=gemma4:12b
LLM_SMART_HOME_SENSORS_GRAPH_CHAT_MODEL=gemma4:12b
LLM_SMART_HOME_CAMERAS_GRAPH_CHAT_MODEL=gemma4:12b
LLM_MEMORY_GRAPH_CHAT_MODEL=gemma4:12b
LLM_VEHICLE_MAINTENANCE_GRAPH_CHAT_MODEL=gemma4:12b
LLM_VEHICLE_MAINTENANCE_VISION_MODEL=          # empty = maintenance graph model; point only the receipt vision call to a stronger OCR model (e.g. gemma4:27b)
LLM_CALCULATOR_GRAPH_CHAT_MODEL=gemma4:12b
LLM_CONTEXT_SUMMARY_GRAPH_CHAT_MODEL=gemma4:12b
LLM_CONTEXT_SUMMARY_GRAPH_CHAT_TEMPERATURE=0.2  # fidelity over creativity; 0.1 makes the 12b telegraphic on long text
LLM_USER_SETTINGS_GRAPH_CHAT_MODEL=gemma4:12b
LLM_USER_SETTINGS_GRAPH_CHAT_TEMPERATURE=0.1    # classifier: the LLM only transcribes the city, Python resolves the IANA id

# Timezone used for a user who never set one (no row in `user_settings`). The
# user changes it via chat ("altere o timezone para São Paulo"). This is the only
# place a timezone literal lives.
DEFAULT_TIMEZONE=America/Sao_Paulo

# Pending multi-turn maintenance flow (register/edit/delete/choose_vehicle) TTL
# in seconds. Longer than the shopping-list disambiguation TTL since collecting
# vehicle -> date -> km spans several turns.
MAINTENANCE_FLOW_TTL_SECONDS=600

# NLP (spaCy model used for Portuguese entity/text processing)
NLP_SPACY_MODEL=pt_core_news_sm

# Home Assistant
HOME_ASSISTANT_URL=http://<ha-host>:8123
HOME_ASSISTANT_TOKEN=<long-lived-token>

# Music Assistant (optional). When URL/token are unset the music graph is not
# wired and music intents are ignored.
MUSIC_ASSISTANT_URL=http://<music-assistant-host>:8095
MUSIC_ASSISTANT_TOKEN=
LLM_MUSIC_GRAPH_CHAT_MODEL=gemma4:12b

# Databases
PERUCA_DB_CONNECTION_STRING=sqlite:///data/peruca.db
CACHE_DB_CONNECTION_STRING=
# Conversation-history expiry in Redis. Leave empty (or omit) for no expiry.
# A value of 0 or below is also treated as "no expiry" — it does NOT delete
# the history. Set a positive number of seconds to expire idle conversations.
# The compaction summary (chat_summary:{user_id}) shares this TTL and is renewed
# on every turn alongside the history, so it never outlives the turns it covers.
CHAT_HISTORY_TTL_SECONDS=

# Chat context compaction. When the history grows past a trigger, a background
# task summarizes the OLD part of the conversation and keeps only the recent
# tail verbatim — so a long conversation no longer forgets how it started.
# Runs off the request path (a FastAPI BackgroundTask), never blocking a reply.
#
# IMPORTANT: the compaction swap is guarded by an in-process lock (threading),
# so the API MUST run with a SINGLE worker. With multiple workers a compaction
# in one worker can overwrite turns appended by another. Migrating the swap to a
# Redis Lua script is the prerequisite for multi-worker.
CHAT_COMPACTION_ENABLED=true
CHAT_COMPACTION_TRIGGER_MESSAGES=30     # fires when the history reaches this many messages
CHAT_COMPACTION_TRIGGER_CHARS=24000     # secondary trigger (~6k tokens), whichever comes first
CHAT_COMPACTION_KEEP_TAIL_MESSAGES=16   # recent messages kept verbatim (8 turns; even = turn boundary)
CHAT_COMPACTION_MAX_SUMMARY_CHARS=2500  # summary cap, truncated at a whole-bullet boundary
