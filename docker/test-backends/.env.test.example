# Template for docker/test-backends/.env.test (which is git-ignored).
#
# bootstrap_ha.py reads this file (copying it to .env.test on first run) and
# writes the minted HOME_ASSISTANT_TOKEN back into .env.test. The integration
# wrapper (run-integration-tests.sh) then `source`s .env.test so pytest picks
# these up from the process environment (conftest.py reads os.environ).

# Backend endpoints (published by docker-compose.dev.yml on localhost).
HOME_ASSISTANT_URL=http://localhost:8123
MUSIC_ASSISTANT_URL=http://localhost:8095
TEST_REDIS_URL=redis://localhost:6379/15

# Filled automatically by bootstrap_ha.py — leave empty here.
HOME_ASSISTANT_TOKEN=

# Owner credentials for the throwaway test HA instance. Used ONLY by
# bootstrap_ha.py (onboarding on a fresh instance, login on re-runs). These are
# NOT secrets — the HA instance is local, disposable and never exposed.
HA_BOOTSTRAP_USERNAME=peruca
HA_BOOTSTRAP_PASSWORD=peruca-test-password
